NODE_ENV=development
APP_ENV=development
PORT=4000
CLIENT_ORIGINS=http://localhost:8081
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/faceme
JWT_ACCESS_SECRET=replace-with-a-64-plus-character-secret
JWT_REFRESH_SECRET=replace-with-another-64-plus-character-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=faceme-api
JWT_AUDIENCE=faceme-mobile
LOG_LEVEL=debug
ALLOW_SEED_IN_PRODUCTION=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=faceme-dev
MEDIA_MAX_FILE_SIZE_BYTES=10485760
