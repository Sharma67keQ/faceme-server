NODE_ENV=production
APP_ENV=production
PORT=4000
CLIENT_ORIGINS=https://app.faceme.app,https://faceme.app
DATABASE_URL=postgresql://postgres:replace-me@db-host:5432/faceme
JWT_ACCESS_SECRET=replace-with-a-64-plus-character-secret
JWT_REFRESH_SECRET=replace-with-a-different-64-plus-character-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=faceme-api
JWT_AUDIENCE=faceme-mobile
LOG_LEVEL=info
ALLOW_SEED_IN_PRODUCTION=false
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
CLOUDINARY_FOLDER=faceme
MEDIA_MAX_FILE_SIZE_BYTES=10485760
